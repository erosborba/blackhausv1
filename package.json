{
  "name": "blackhaus-sdr",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "tunnel": "ngrok http --url=repackage-iron-shanty.ngrok-free.dev 3000",
    "webhook:dev": "node scripts/set-webhook.mjs dev",
    "webhook:prod": "node scripts/set-webhook.mjs prod",
    "webhook:status": "node scripts/set-webhook.mjs status",
    "eval": "node scripts/eval-run.mjs",
    "eval:seed": "node scripts/eval-seed.mjs",
    "eval:emps": "node scripts/eval-list-emps.mjs",
    "test:unit": "node --test --experimental-strip-types --no-warnings src/lib/__tests__/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@langchain/anthropic": "^0.3.15",
    "@langchain/core": "^0.3.40",
    "@langchain/langgraph": "^0.2.50",
    "@langchain/langgraph-checkpoint-postgres": "^0.0.3",
    "@langchain/openai": "^0.3.17",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "exceljs": "^4.4.0",
    "next": "^15.5.15",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.15",
    "typescript": "^5.7.3"
  }
}
