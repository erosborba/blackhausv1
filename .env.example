# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...
# Direct Postgres URL (use the "Connection pooling" URI from Supabase, mode=session)
SUPABASE_DB_URL=postgresql://postgres.xxxx:password@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# --- LLMs ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Evolution API (WhatsApp) ---
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me-strong-key
EVOLUTION_INSTANCE=blackhaus
# Shared secret used to validate inbound webhooks (set in evolution config)
EVOLUTION_WEBHOOK_SECRET=change-me-webhook-secret

# --- App ---
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
