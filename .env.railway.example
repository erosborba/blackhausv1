# =========================================================
# Variáveis de ambiente para Railway
# Copie cada bloco para o serviço correspondente no Railway.
# =========================================================

# ─────────────────────────────────────────────────────────
# SERVIÇO 1: evolution-api  (image: atendai/evolution-api:v2.2.3)
# ─────────────────────────────────────────────────────────
SERVER_TYPE=http
SERVER_PORT=8080
CORS_ORIGIN=*
AUTHENTICATION_API_KEY=GERE-UMA-CHAVE-FORTE-AQUI
LANGUAGE=pt-BR
LOG_LEVEL=ERROR,WARN,INFO
DEL_INSTANCE=false

# Postgres do plugin Railway → Reference Variable
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=${{Postgres.DATABASE_URL}}
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange
# Persistência completa em Postgres (substitui a necessidade de volume)
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# Redis do plugin Railway → Reference Variable
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=${{Redis.REDIS_URL}}/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_LOCAL_ENABLED=false

# Webhook aponta para o serviço Next.js (domínio próprio)
WEBHOOK_GLOBAL_URL=https://lumihaus.com.br/api/webhook/evolution
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_QRCODE_UPDATED=true
# Header de autenticação enviado em cada webhook (lido pela rota como `apikey`)
WEBHOOK_REQUEST_HEADERS={"apikey":"GERE-UM-WEBHOOK-SECRET-FORTE"}

# Volume Railway: monte um Volume em /evolution/instances
# (sem isso, a sessão do WhatsApp some a cada redeploy)

# ─────────────────────────────────────────────────────────
# SERVIÇO 2: web (Next.js — esse repo)
# ─────────────────────────────────────────────────────────
# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://gytrnbevbeezflejicbe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...
SUPABASE_DB_URL=postgresql://postgres.gytrnbevbeezflejicbe:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# LLMs
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Evolution (domínio próprio)
EVOLUTION_BASE_URL=https://wa.lumihaus.com.br
EVOLUTION_API_KEY=A-MESMA-CHAVE-DE-AUTHENTICATION_API_KEY
EVOLUTION_INSTANCE=lumihaus
EVOLUTION_WEBHOOK_SECRET=O-MESMO-SECRET-DO-WEBHOOK_REQUEST_HEADERS

# App
APP_BASE_URL=https://lumihaus.com.br
NODE_ENV=production
